{
  "name": "skyrim-alchemy-calculator",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "scrape": "bun run scripts/scrape-ingredients.ts",
    "scrape:effects": "bun run scripts/scrape-effects.ts",
    "db:seed": "bun run scripts/seed-db.ts",
    "dev:server": "bun run --cwd server dev",
    "dev:web": "bun run --cwd web dev",
    "dev": "concurrently -k \"bun run dev:server\" \"bun run dev:web\"",
    "test": "bun test",
    "build": "bun run --cwd web build"
  },
  "devDependencies": {
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
