# Copy to .env next to docker-compose.yml and adjust values.

# Image from GHCR (see .github/workflows/docker-publish.yml); must match your registry path (lowercase).
APP_IMAGE=ghcr.io/your-github-user/skyrimalchemycalculator:latest

# Host directory mounted at /data in the app container (persistent SQLite lives here).
DATA_DIR=/var/lib/skyrim-alchemy/data

# Hostname Caddy serves and obtains certificates for (e.g. alchemy.example.com).
SITE_ADDRESS=alchemy.example.com
